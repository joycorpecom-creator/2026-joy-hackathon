{
  "agent_manifest": "joyagent.md",
  "read_order": [
    "joyagent.md",
    "HERMES_PROJECT_INDEX.md",
    "main.py",
    "agent_runtime/orchestrator.py",
    "agent_runtime/planner.py",
    "agent_runtime/executor.py",
    "agent.py",
    "burgerprints.py",
    "mockup_engine.py",
    "static/index.html"
  ],
  "required_context_before_work": [
    "Read joyagent.md first",
    "For planner/tool-choice routing, read agent_runtime/",
    "For API client, read burgerprints.py",
    "For mockup pipeline, read mockup_engine.py"
  ],
  "core_files": {
    "web_api": "main.py",
    "agent_loop": "agent.py",
    "runtime": "agent_runtime/orchestrator.py",
    "planner": "agent_runtime/planner.py",
    "executor": "agent_runtime/executor.py",
    "memory": "burger_memory.py",
    "mockup_engine": "mockup_engine.py",
    "design_compositor": "design_compositor.py",
    "image_preprocess": "image_preprocess.py",
    "integrity": "integrity.py",
    "providers": "providers.py",
    "bp_api": "burgerprints.py",
    "ui": "static/index.html"
  },
  "rules": {
    "current_request_overrides_memory": true,
    "preserve_design_pixels": true,
    "output_min_size": "1500x1500",
    "judge_setup_max_minutes": 15,
    "no_real_brand_logos": true,
    "no_celebrity_faces": true
  }
}
