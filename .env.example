# JOY-DNSE Mockup Studio — environment template

# Required: BurgerShop/BurgerPrints seller-product API
BURGERPRINTS_API_KEY=
BURGERPRINTS_BASE_URL=https://api.burgerprints.com/v1

# Required: Gemini text + image generation
GEMINI_API_KEY=
TEXT_MODEL=gemini-3-flash-preview
IMAGE_MODEL=gemini-3.1-flash-image

# Local web preview
PUBLIC_BASE_URL=http://127.0.0.1:8000
HOST=0.0.0.0
PORT=8000

# Optional: upload generated mockups to public image hosting before product update
IMGBB_API_KEY=

# Optional: sync events to automation tools
SYNC_ENABLED=false
SYNC_PROVIDER=n8n
SYNC_WEBHOOK_URL=

# Optional: Telegram bot mode
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Optional: Lark/Base self-hosted sync
LARK_APP_ID=
LARK_APP_SECRET=
LARK_BASE_TOKEN=
LARK_TABLE_ID=
LARK_ATTACHMENT_FIELD_ID=
