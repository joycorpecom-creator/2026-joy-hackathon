# BurgerMockup Bot — local judge/demo config

# Required
BURGERPRINTS_API_KEY=
BURGERPRINTS_BASE_URL=https://api.burgerprints.com/v2
GEMINI_API_KEY=
IMGBB_API_KEY=5c9d36c4d8f45696febcd30403b28028

# Local web preview. Keep default for local install.
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Demo sync: app posts to n8n, n8n writes to preconfigured Lark Base.
SYNC_ENABLED=true
SYNC_PROVIDER=n8n


# Optional Telegram mode
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# Optional only if self-hosting Lark/Base, not needed for judge demo
LARK_APP_ID=
LARK_APP_SECRET=
LARK_BASE_TOKEN=
LARK_TABLE_ID=
LARK_ATTACHMENT_FIELD_ID=fldfkDRB21
